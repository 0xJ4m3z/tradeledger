# TradeLedger environment variables
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real addresses or keys.

# Optional: custom Polygon JSON-RPC endpoint
# Defaults to https://polygon-rpc.com (public, no key required)
# POLYGON_RPC_URL=https://polygon-rpc.com

# Optional: pre-fill your wallet address on startup (convenience only)
# Never required — you can always type it in the app
# WALLET_ADDRESS=0x...
